{
  "name": "whoosh-be",
  "version": "1.0.0",
  "description": "Whoosh train ticket booking application",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "tsx src/app.ts",
    "lint": "eslint 'src/**/*.{ts,js}'",
    "lint:fix": "eslint 'src/**/*.{ts,js}' --fix",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate": "tsx node_modules/knex/bin/cli.js migrate:latest",
    "migrate:rollback": "tsx node_modules/knex/bin/cli.js migrate:rollback",
    "migrate:fresh": "tsx node_modules/knex/bin/cli.js migrate:rollback --all && tsx node_modules/knex/bin/cli.js migrate:latest",
    "seed": "tsx node_modules/knex/bin/cli.js seed:run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.2.9",
    "mysql2": "^3.22.3",
    "uuid": "^14.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/knex": "^0.15.2",
    "@types/node": "^22.19.17",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.31.0",
    "fast-check": "^3.21.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.1",
    "ts-jest": "^29.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
